ame":"loeck","email":"loeck@mailjet.com"},{"name":"mjmlio","email":"hi@mjml.io"},{"name":"ngarnier","email":"nicolas.garnier1@yahoo.fr"}],"_npmOperationalInternal":{"host":"s3://npm-registry-packages","tmp":"tmp/mjml-navbar-3.3.5.tgz_1506347189144_0.954066262813285"},"directories":{}},"4.0.0-beta.1":{"name":"mjml-navbar","description":"mjml-navbar","version":"4.0.0-beta.1","main":"lib/index.js","repository":{"type":"git","url":"git+https://github.com/mjmlio/mjml.git"},"license":"MIT","bugs":{"url":"https://github.com/mjmlio/mjml/issues"},"homepage":"https://mjml.io","scripts":{"clean":"../../node_modules/.bin/rimraf lib","build":"../../node_modules/.bin/babel src --out-dir lib"},"dependencies":{"lodash":"^4.17.2","mjml-core":"^4.0.0-beta.1"},"_id":"mjml-navbar@4.0.0-beta.1","_npmVersion":"5.5.1","_nodeVersion":"9.1.0","_npmUser":{"name":"iryusa","email":"maxime.brazeilles@gmail.com"},"dist":{"integrity":"sha512-seF3YTaStHzHUEL1EDJCEKKW6UxaGd0KRisyGLoPwbUx+sMTGlmAIbnt9ZsLJ208ECnzYEYJEIudVwP6+s0bRw==","shasum":"591aba98f58817cbe74dd8bd6c06d8b37def956a","tarball":"https://registry.npmjs.org/mjml-navbar/-/mjml-navbar-4.0.0-beta.1.tgz","signatures":[{"keyid":"SHA256:jl3bwswu80PjjokCgh0o2w5c2U4LhQAE57gj9cz1kzA","sig":"MEYCIQDfTQM9vedMgA1gpj/zwiRcYEoPMNdgn0Dpx9DWjORSaAIhAKFHyOpkRKKowYGS62tCm3Z7VQOGW8hH+rJfK+/lfzz5"}]},"maintainers":[{"email":"meriadec.pillet@gmail.com","name":"meriadec"},{"email":"nicolas.garnier1@yahoo.fr","name":"ngarnier"},{"email":"loeck@mailjet.com","name":"loeck"},{"email":"maxime.brazeilles@gmail.com","name":"iryusa"},{"email":"hi@mjml.io","name":"mjmlio"}],"_npmOperationalInternal":{"host":"s3://npm-registry-packages","tmp":"tmp/mjml-navbar-4.0.0-beta.1.tgz_1516633158275_0.7723765911068767"},"directories":{}},"4.0.0-beta.2":{"name":"mjml-navbar","description":"mjml-navbar","version":"4.0.0-beta.2","main":"lib/index.js","repository":{"type":"git","url":"git+https://github.com/mjmlio/mjml.git"},"license":"MIT","bugs":{"url":"https://github.com/mjmlio/mjml/issues"},"homepage":"https://mjml.io","scripts":{"clean":"../../node_modules/.bin/rimraf lib","build":"../../node_modules/.bin/babel src --out-dir lib"},"dependencies":{"lodash":"^4.17.2","mjml-core":"^4.0.0-beta.2"},"readme":"## mjml-navbar\n\n<p align=\"center\">\n  <img src=\"https://cloud.githubusercontent.com/assets/1830348/15317906/d6cef510-1c23-11e6-83d7-31e4e4f8ba2a.png\" width=\"800px\" />\n</p>\n\nDisplays a menu for navigation with an optional hamburger mode for mobile devices.\n\n```xml\n<mjml>\n  <mj-body>\n    <mj-section background-color=\"#ef6451\">\n      <mj-column>\n        <mj-navbar base-url=\"https://mjml.io\" hamburger=\"hamburger\" ico-color=\"#ffffff\">\n            <mj-navbar-link href=\"/gettings-started-onboard\" color=\"#ffffff\">Getting started</mj-navbar-link>\n            <mj-navbar-link href=\"/try-it-live\" color=\"#ffffff\">Try it live</mj-navbar-link>\n            <mj-navbar-link href=\"/templates\" color=\"#ffffff\">Templates</mj-navbar-link>\n            <mj-navbar-link href=\"/components\" color=\"#ffffff\">Components</mj-navbar-link>\n        </mj-navbar>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>\n```\n\n<p align=\"center\">\n  <a target=\"_blank\" href=\"/try-it-live/components/navbar\">\n    <img width=\"100px\" src=\"https://mjml.io/assets/img/svg/TRYITLIVE.svg\" alt=\"try it live\" />\n  </a>\n</p>\n\n### mjml-navbar\n\nIndividual links of the menu should we wrapped inside mj-navbar.\n\n\nStandard Desktop:\n\n<p align=\"center\">\n  <img src=\"https://cloud.githubusercontent.com/assets/1830348/15317906/d6cef510-1c23-11e6-83d7-31e4e4f8ba2a.png\" width=\"800px\" />\n</p>\n\nStandard Mobile:\n\n<p align=\"center\">\n  <img src=\"https://cloud.githubusercontent.com/assets/1830348/15317917/e514d0a4-1c23-11e6-8e5a-c23da9ac1d4e.png\" width=\"318px\" />\n</p>\n\nMode hamburger enabled:\n\n<p align=\"center\">\n  <img src=\"https://cloud.githubusercontent.com/assets/1830348/15317922/f01c5c24-1c23-11e6-9b0c-95b0602da260.gif\" width=\"309px\" />\n</p>\n\n<aside class=\"notice\">\n  The \"hamburger\" feature only work on mobile device with all iOS mail client, for others mail clients the render is performed on an normal way, the links are displayed inline and the hamburger is not visible.\n</aside>\n\n<aside class=\"notice\">\n  All the attributes prefixed with <code>ico-</code> help to customize the hamburger icon. They only work with the hamburger mode enabled.\n</aside>\n\nattribute                   | unit               | description                                                                                      | default value\n----------------------------|--------------------|--------------------------------------------------------------------------------------------------|-----------------\nbase url                    | string             | base url for children components                                                                 | n/a\nhamburger                   | string             | activate the hamburger navigation on mobile if the value is hamburger                            | n/a\nalign                       | string             | align content left/center/right                                                                  | center\nico-open                    | ASCII code decimal | char code for a custom open icon (hamburger mode required)                                       | 9776\nico-close                   | ASCII code decimal | char code for a custom close icon (hamburger mode required)                                      | 8855\nico-padding                 | px                 | hamburger icon padding, supports up to 4 parameters (hamburger mode required)                    | 10px\nico-padding-top             | px                 | hamburger icon top offset (hamburger mode required)                                              | 10px\nico-padding-right           | px                 | hamburger icon right offset (hamburger mode required)                                            | 10px\nico-padding-bottom          | px                 | hamburger icon bottom offset (hamburger mode required)                                           | 10px\nico-padding-left            | px                 | hamburger icon left offset (hamburger mode required)                                             | 10px\nico-align                   | string             | hamburger icon alignment, left/center/right (hamburger mode required)                            | center\nico-color                   | color format       | hamburger icon color (hamburger mode required)                                                   | #000000\nico-font-size               | px                 | hamburger icon size (hamburger mode required)                                                    | 30px\nico-font-family             | string             | hamburger icon font (only on hamburger mode)                                                     | Ubuntu, Helvetica, Arial, sans-serif\nico-text-transform          | string             | hamburger icon text transformation none/capitalize/uppercase/lowercase (hamburger mode required) | none\nico-text-decoration         | string             | hamburger icon text decoration none/underline/overline/line-through (hamburger mode required)    | none\nico-line-height             | px                 | hamburger icon line height (hamburger mode required)                                             | 30px\n\n\n### mjml-navbar-link\n\n\nThis component should be used to display an individual link in the navbar.\n\n<aside class=\"notice\">\n  The mj-navbar-link component must be used inside a mj-navbar component only.\n</aside>\n\nattribute        | unit          | description                           | default value\n-----------------|---------------|---------------------------------------|------------------------------\ncolor            | color         | text color                            | #000000\nfont-family      | string        | font                                  | Ubuntu, Helvetica, Arial, sans-serif\nfont-size        | px            | text size                             | 13px\nfont-style       | string        | normal/italic/oblique                 | n/a\nfont-weight      | number        | text thickness                        | n/a\nline-height      | px            | space between the lines               | 22px\ntext-decoration  | string        | underline/overline/none               | n/a\ntext-transform   | string        | capitalize/uppercase/lowercase/none   | uppercase\npadding          | px            | supports up to 4 parameters           | 10px 25px\npadding-top      | px            | top offset                            | n/a\npadding-bottom   | px            | bottom offset                         | n/a\npadding-left     | px            | left offset                           | n/a\npadding-right    | px            | right offset                          | n/a\nrel              | string        | specify the rel attribute             | n/a\n","readmeFilename":"README.md","_id":"mjml-navbar@4.0.0-beta.2","_npmVersion":"5.5.1","_nodeVersion":"9.1.0","_npmUser":{"name":"iryusa","email":"maxime.brazeilles@gmail.com"},"dist":{"integrity":"sha512-xNEy/VcgZ917El4gLlM/2O8fCw2xn4fXyvPdjBKoVOQH1YVG0edRFZ+W94bTRTYXlH9KIFbp03szR3NeoJ2o6Q==","shasum":"45f54453c97a14b043dad94f8ca1ca92c16146cf","tarball":"https://registry.npmjs.org/mjml-navbar/-/mjml-navbar-4.0.0-beta.2.tgz","fileCount":8,"unpackedSize":33535,"signatures":[{"keyid":"SHA256:jl3bwswu80PjjokCgh0o2w5c2U4LhQAE57gj9cz1kzA","sig":"MEUCIEBMUIgILGHKopY0dcTLkmJnzSmlo9ePwsIeY9HH/cw7AiEAw1xiTt3BycXJrs8joZm0DjQG8aGFEO25+HahNyCZnw0="}]},"maintainers":[{"email":"maxime.brazeilles@gmail.com","name":"iryusa"},{"email":"loeck@mailjet.com","name":"loeck"},{"email":"meriadec.pillet@gmail.com","name":"meriadec"},{"email":"hi@mjml.io","name":"mjmlio"},{"email":"nicolas.garnier1@yahoo.fr","name":"ngarn