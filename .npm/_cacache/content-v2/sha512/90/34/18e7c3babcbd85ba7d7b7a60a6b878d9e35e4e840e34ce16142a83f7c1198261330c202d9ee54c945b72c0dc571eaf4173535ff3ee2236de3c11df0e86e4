\n\nUsage:\n\n```javascript\nimport {expect} from 'chai';\nimport React, {Component} from 'react';\nimport getDisplayName from 'react-display-name';\n\nconst container = (WrappedComponent) => {\n  class Container extends Component {\n    static displayName = `Container(${getDisplayName(WrappedComponent)})`;\n    render() {\n      return (\n        <WrappedComponent />\n      );\n    }\n  }\n  return Container;\n}\n\nclass HelloWorld extends Component {\n  render() {\n    return (\n      <div>Hello</div>\n    );\n  }\n}\n\nconst HelloWorldPrime = container(HelloWorld);\n\nexpect(getDisplayName(HelloWorldPrime)).to.equal('Container(HelloWorld)');\nexpect(HelloWorldPrime.displayName).to.equal('Container(HelloWorld)');\n```\n","maintainers":[{"name":"jurassix","email":"clinton.ayres@gmail.com"}],"time":{"modified":"2022-06-25T20:10:50.127Z","created":"2015-10-07T18:18:06.586Z","0.0.1":"2015-10-07T18:18:06.586Z","0.1.1":"2016-01-13T18:12:56.294Z","0.2.0":"2016-04-28T17:17:02.697Z","0.2.3":"2017-07-31T18:47:58.572Z","0.2.4":"2018-04-13T03:50:46.484Z","0.2.5":"2019-12-01T03:25:01.268Z"},"homepage":"https://github.com/jurassix/react-display-name#readme","keywords":["react","redux","getDisplayName"],"repository":{"type":"git","url":"git+https://github.com/jurassix/react-display-name.git"},"author":{"name":"jurassix","url":"clinton.ayres@gmail.com"},"bugs":{"url":"https://github.com/jurassix/react-display-name/issues"},"license":"MIT","readmeFilename":"README.md"}