f background-size is not specified, no-repeat will be ignored on Outlook.\n  - If the specified size is a single attribute in percent, the height will be auto as in standard css. On outlook, the image will never overflow the element, and it will be shrinked instead of being cropped like on other clients.\n</aside>\n","readmeFilename":"README.md","_id":"mjml-section@4.7.0-beta.2","_nodeVersion":"12.14.1","_npmVersion":"lerna/3.22.1/node@v12.14.1+x64 (darwin)","dist":{"integrity":"sha512-z64xAat+nelmp7zSqH7UxA+IEjFE1YbRRi8i1VS4/UNTh4iVeTaYEZJ8yoR4jLJJla3N3FYEBhyV/qVxHxainQ==","shasum":"cb0660bb7474b1c4a8448daca8531bb86b21cd34","tarball":"https://registry.npmjs.org/mjml-section/-/mjml-section-4.7.0-beta.2.tgz","fileCount":4,"unpackedSize":22855,"npm-signature":"-----BEGIN PGP SIGNATURE-----\r\nVersion: OpenPGP.js v3.0.4\r\nComment: https://openpgpjs.org\r\n\r\nwsFcBAEBCAAQBQJfSSN3CRA9TVsSAnZWagAADgkP/jX4fmXd6iseEqyyN0Ts\ndAGfuBAh2gB+PbuuFV/MamfFATNMeAZQyswhRaFseWxYbv1IA6vcX7Pi0zFJ\n/p6wEOvKA3OGtVfstCn6kamMyOdt32BH7stjdzZCOk/kpQae6ee88VMK2p/z\nB5occOwq3Ek9nkr9QiF9t0qSSA0uV2ChAb+dbkn7FOsK5GbAad2Arwt4VJE3\nPpmucOcPCpIqmsGC4yVzUBOK1EohyPEU036AiAE7cNPQZYgGp7KDnLnxQtfm\nWXJ5gfsIZmKXWoRt62T8K3/zQ+szegth5FPyuyOrblbJZSMKzz+KAXsxRGwB\nGxokrobolJL39ZLlCFwRMWvD08PoZvT+V0o2vdn2UnI4LaCXh0BD9YU5q1Jg\nNhkpRNFNNe5cP8p0yw5C5wJQZwLE08i2lMQpx5FGuBYtP2a1msLzsqqQXMZi\nybfue9a5Z7nSNGFVIJe/BKeqFMWp73lcwNKAa4CwGuTD/DhG5mqi50Ty7WSe\n57tB4nFp6ypcb8z5ucDJXImBfZRVIy4EnfFUZDZZjbLN7W778GvQlnJyBoch\nOuAEGCm0/sNk2qI91yhFN979GL/y74dlb2x7drq0Lcya5X5xq0tarl8Zp5P5\nZwvcjGKPBcJ68xM7fvGrFg4BjQTVUOqT1zKbaOfAqQ8OefoCaajyqueOK+4W\nm3eQ\r\n=Pi7h\r\n-----END PGP SIGNATURE-----\r\n","signatures":[{"keyid":"SHA256:jl3bwswu80PjjokCgh0o2w5c2U4LhQAE57gj9cz1kzA","sig":"MEUCIQCcP88AKW+4PUIKA2x7ITCWzi5YnYg70U3LpcY3zU2pCwIgUbTY1uisuxWJWQtOGBvrPfu+wMYHr7Yq9JjNSXqrcWs="}]},"maintainers":[{"email":"maxime.brazeilles@gmail.com","name":"iryusa"},{"email":"cavrois.cedric@hotmail.fr","name":"kmcb"},{"email":"loeck@mailjet.com",